generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  facebookId      String            @unique
  email           String?
  name            String?
  accessToken     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  duplicateJobs   DuplicateJob[]
  accounts        FacebookAccount[]
  namingTemplates NamingTemplate[]
}

model FacebookAccount {
  id           String   @id @default(cuid())
  adAccountId  String   @unique
  name         String
  currency     String?
  timezoneName String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model DuplicateJob {
  id        String   @id @default(cuid())
  userId    String
  status    String
  type      String
  sourceId  String
  targetId  String?
  details   Json?
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model NamingTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  pattern   String
  type      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}
